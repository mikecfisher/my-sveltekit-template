{
	"name": "my-sveltekit-template",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "USE_LOCAL_CONVEX=true portless run vite dev",
		"dev:hosted": "portless run vite dev",
		"convex:dash": "docker run --rm -p 6791:6791 -e NEXT_PUBLIC_DEPLOYMENT_URL=http://127.0.0.1:3210 ghcr.io/get-convex/convex-dashboard:latest",
		"convex:gen": "CONVEX_AGENT_MODE=anonymous convex codegen",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && oxlint",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"check:all": "bun run lint && bun run format && bun run test && bun run check"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^6.3.1",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^24",
		"eslint-plugin-svelte": "^3.14.0",
		"happy-dom": "^20.8.9",
		"oxlint": "^1.57.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@clerk/backend": "^3.2.0",
		"@clerk/clerk-js": "^6.3.0",
		"@clerk/ui": "^1.2.1",
		"@effect/platform-node": "^4.0.0-beta.31",
		"@tanstack/svelte-form": "^1.28.6",
		"@tanstack/svelte-hotkeys": "^0.9.0",
		"@tanstack/svelte-query": "^6.1.11",
		"convex": "^1.33.0",
		"convex-helpers": "^0.1.114",
		"convex-svelte": "^0.0.12",
		"convex-vite-plugin": "^0.4.0",
		"effect": "^4.0.0-beta.31"
	}
}
